local function UpdateESP()
    if not Config.ESP.Enabled then
        for _, objs in pairs(EspObjects) do
            if objs.box then objs.box.Visible = false end
            if objs.line then objs.line.Visible = false end
            if objs.text then objs.text.Visible = false end
        end
        return
    end

    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X/2, viewport.Y/2)
    local camPos = Camera.CFrame.Position

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not IsAlive(player) then
            if EspObjects[player] then
                if EspObjects[player].box then EspObjects[player].box.Visible = false end
                if EspObjects[player].line then EspObjects[player].line.Visible = false end
                if EspObjects[player].text then EspObjects[player].text.Visible = false end
            end
            continue
        end

        if Config.ESP.TeamCheck and IsTeam(player) then
            if EspObjects[player] then
                if EspObjects[player].box then EspObjects[player].box.Visible = false end
                if EspObjects[player].line then EspObjects[player].line.Visible = false end
                if EspObjects[player].text then EspObjects[player].text.Visible = false end
            end
            continue
        end

        local char = player.Character
        if not char then continue end

        local head = char:FindFirstChild("Head")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not head or not root then continue end

        local dist = (head.Position - camPos).Magnitude
        if dist > Config.ESP.MaxDistance then
            if EspObjects[player] then
                if EspObjects[player].box then EspObjects[player].box.Visible = false end
                if EspObjects[player].line then EspObjects[player].line.Visible = false end
                if EspObjects[player].text then EspObjects[player].text.Visible = false end
            end
            continue
        end

        local headPos, headOn = Camera:WorldToViewportPoint(head.Position)
        if not headOn then
            if EspObjects[player] then
                if EspObjects[player].box then EspObjects[player].box.Visible = false end
                if EspObjects[player].line then EspObjects[player].line.Visible = false end
                if EspObjects[player].text then EspObjects[player].text.Visible = false end
            end
            continue
        end

        local footPos
        local footParts = {"LeftFoot", "RightFoot", "LeftLeg", "RightLeg"}
        for _, name in ipairs(footParts) do
            local part = char:FindFirstChild(name)
            if part then
                footPos, _ = Camera:WorldToViewportPoint(part.Position)
                break
            end
        end

        if not footPos then
            local rootPos, _ = Camera:WorldToViewportPoint(root.Position)
            if rootPos then
                footPos = Vector2.new(rootPos.X, rootPos.Y + (headPos.Y - rootPos.Y) * 0.6)
            end
        end

        if not footPos then
            if EspObjects[player] then
                if EspObjects[player].box then EspObjects[player].box.Visible = false end
                if EspObjects[player].line then EspObjects[player].line.Visible = false end
                if EspObjects[player].text then EspObjects[player].text.Visible = false end
            end
            continue
        end

        local height = math.abs(headPos.Y - footPos.Y) + 15
        local width = height * 0.45

        if height < 10 or height > viewport.Y then
            if EspObjects[player] then
                if EspObjects[player].box then EspObjects[player].box.Visible = false end
                if EspObjects[player].line then EspObjects[player].line.Visible = false end
                if EspObjects[player].text then EspObjects[player].text.Visible = false end
            end
            continue
        end

        local x = headPos.X - width/2
        local y = footPos.Y - height

        if not EspObjects[player] then
            EspObjects[player] = {
                box = Drawing.new("Square"),
                line = Drawing.new("Line"),
                text = Drawing.new("Text")
            }
            EspObjects[player].box.Thickness = 2
            EspObjects[player].box.Transparency = 0.6
            EspObjects[player].box.Filled = false
            EspObjects[player].line.Thickness = 1
            EspObjects[player].line.Color = Color3.fromRGB(255, 255, 255)
            EspObjects[player].line.Transparency = 0.4
            EspObjects[player].text.Color = Color3.fromRGB(255, 255, 255)
            EspObjects[player].text.Size = 14
            EspObjects[player].text.Font = 3
            EspObjects[player].text.Outline = true
            EspObjects[player].text.OutlineColor = Color3.fromRGB(0, 0, 0)
            EspObjects[player].text.Center = true
        end

        local objs = EspObjects[player]
        local hum = char:FindFirstChild("Humanoid")
        local hp = hum and (hum.Health / hum.MaxHealth) or 1

        objs.box.Size = Vector2.new(width, height)
        objs.box.Position = Vector2.new(x, y)
        objs.box.Visible = true

        if hp < 0.25 then
            objs.box.Color = Color3.fromRGB(255, 0, 0)
        elseif hp < 0.5 then
            objs.box.Color = Color3.fromRGB(255, 255, 0)
        else
            objs.box.Color = Color3.fromRGB(0, 255, 0)
        end

        if Config.ESP.ShowTracers then
            objs.line.From = Vector2.new(center.X, center.Y)
            objs.line.To = Vector2.new(headPos.X, headPos.Y + height/2)
            objs.line.Visible = true
        else
            objs.line.Visible = false
        end

        local hpText = math.floor(hp * 100)
        objs.text.Text = player.Name .. " | " .. hpText .. "%"
        objs.text.Position = Vector2.new(headPos.X, y - 22)
        objs.text.Visible = true
    end
end

