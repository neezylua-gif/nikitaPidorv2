local function CreateExpandedHitbox(player)
    local char = player.Character
    if not char then return end

    if HitboxObjects[player] then
        for _, obj in pairs(HitboxObjects[player]) do
            if obj and obj.Parent then obj:Destroy() end
        end
    end

    HitboxObjects[player] = {}

    for _, partName in ipairs(Config.HitboxExpander.PartsToExpand) do
        local originalPart = char:FindFirstChild(partName)
        if originalPart and originalPart:IsA("BasePart") then
            local expander = Instance.new("Part")
            expander.Name = "HitboxExpander_" .. partName
            expander.Transparency = Config.HitboxExpander.TransparencyValue
            expander.CanCollide = false
            expander.Anchored = false
            expander.Massless = true
            expander.Size = originalPart.Size * Config.HitboxExpander.SizeMultiplier
            expander.Color = Color3.fromRGB(255, 0, 0)

            local weld = Instance.new("WeldConstraint")
            weld.Part0 = expander
            weld.Part1 = originalPart
            weld.Parent = expander

            expander.Parent = char
            table.insert(HitboxObjects[player], expander)
        end
    end
end

local function RemoveExpandedHitbox(player)
    if HitboxObjects[player] then
        for _, obj in pairs(HitboxObjects[player]) do
            if obj and obj.Parent then obj:Destroy() end
        end
        HitboxObjects[player] = nil
    end
end

local function UpdateAllHitboxes()
    if Config.HitboxExpander.Enabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and IsAlive(player) then
                if Config.Aimbot.TeamCheck and IsTeam(player) then
                    RemoveExpandedHitbox(player)
                else
                    CreateExpandedHitbox(player)
                end
            else
                RemoveExpandedHitbox(player)
            end
        end
    else
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then RemoveExpandedHitbox(player) end
        end
    end
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function()
        if Config.HitboxExpander.Enabled then
            task.wait(1)
            CreateExpandedHitbox(player)
        end
    end)
end)

