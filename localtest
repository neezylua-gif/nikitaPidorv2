local function UpdateStatus()
    if not Config.ShowStatus then
        StatusText.Visible = false
        return
    end
    StatusText.Visible = true
    local esp = Config.ESP.Enabled and "ON" or "OFF"
    local aim = Config.Aimbot.Enabled and "ON" or "OFF"
    local tb = Config.TriggerBot.Enabled and "ON" or "OFF"
    local bh = Config.BunnyHop.Enabled and "ON" or "OFF"
    local target = LockedTarget or CurrentTarget
    local targetName = target and target.Name or "NONE"
    StatusText.Text = "ESP:"..esp.." | AIM:"..aim.." | TB:"..tb.." | BH:"..bh.." | FOV:"..Config.Aimbot.FOV.." | T:"..targetName
end

