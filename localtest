-- TRIGGER BOT
-- =====================================================
local function TriggerBotCheck()
    if not Config.TriggerBot.Enabled then return false end
    if not Config.Aimbot.Enabled then return false end

    local now = tick()
    if now - TriggerBotLastFire < Config.TriggerBot.Delay then return false end

    local target = LockedTarget or CurrentTarget
    if not target then return false end
    if not IsAlive(target) then return false end
    if Config.TriggerBot.TeamCheck and IsTeam(target) then return false end
    if Config.TriggerBot.WallCheck and not IsVisible(target) then return false end

    local char = target.Character
    if not char then return false end
    local head = char:FindFirstChild("Head")
    if not head then return false end

    local sp, on = Camera:WorldToViewportPoint(head.Position)
    if not on then return false end

    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X/2, viewport.Y/2)
    local v = Vector2.new(sp.X, sp.Y)
    local distToCenter = (v - center).Magnitude

    if distToCenter > Config.Aimbot.FOV then return false end

    return true
end

local function TriggerBotFire()
    TriggerBotLastFire = tick()
    mouse1press()
    task.wait(0.05)
    mouse1release()
end

