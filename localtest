local function UpdateKDAOverlay()
    if not Config.KDA.ShowOverlay then
        KDAOverlay.Visible = false
        return
    end
    
    KDAOverlay.Visible = true
    local kills = Config.KDA.Kills
    local deaths = Config.KDA.Deaths
    local kd = deaths > 0 and string.format("%.1f", kills / deaths) or string.format("%.1f", kills)
    local streak = Config.KDA.CurrentStreak
    local maxStreak = Config.KDA.MaxStreak
    
    KDAOverlay.Text = string.format("K:%d | D:%d | KD:%s | Streak:%d | Max:%d", kills, deaths, kd, streak, maxStreak)
end

local function OnLocalPlayerDeath()
    Config.KDA.Deaths = Config.KDA.Deaths + 1
    Config.KDA.CurrentStreak = 0
    UpdateKDAOverlay()
end

local function OnLocalPlayerKill()
    Config.KDA.Kills = Config.KDA.Kills + 1
    Config.KDA.CurrentStreak = Config.KDA.CurrentStreak + 1
    if Config.KDA.CurrentStreak > Config.KDA.MaxStreak then
        Config.KDA.MaxStreak = Config.KDA.CurrentStreak
    end
    UpdateKDAOverlay()
end

local function StartKDATracking()
    if HealthCheckConnection then return end
    
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then LastHealth = hum.Health end
    end
    
    HealthCheckConnection = RunService.Heartbeat:Connect(function()
        local currentHealth = GetLocalHealth()
        if LastHealth > 0 and currentHealth <= 0 then
            OnLocalPlayerDeath()
        end
        LastHealth = currentHealth
    end)
end

local function TrackKillsFromPlayers()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if player.Character then
                local hum = player.Character:FindFirstChild("Humanoid")
                if hum then
                    hum.Died:Connect(function()
                        if IsAlive(LocalPlayer) then
                            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                            if root then
                                local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                if localRoot then
                                    local dist = (root.Position - localRoot.Position).Magnitude
                                    if dist < 200 then OnLocalPlayerKill() end
                                end
                            end
                        end
                    end)
                end
            end
            player.CharacterAdded:Connect(function(character)
                local hum = character:WaitForChild("Humanoid")
                hum.Died:Connect(function()
                    if IsAlive(LocalPlayer) then
                        local root = character:FindFirstChild("HumanoidRootPart")
                        if root then
                            local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if localRoot then
                                local dist = (root.Position - localRoot.Position).Magnitude
                                if dist < 200 then OnLocalPlayerKill() end
                            end
                        end
                    end
                end)
            end)
        end
    end
end

