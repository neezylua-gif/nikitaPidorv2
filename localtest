RunService.RenderStepped:Connect(function()
    UpdateESP()
    UpdateAntiAim()

    local viewport = Camera.ViewportSize
    FOVCircle.Position = Vector2.new(viewport.X/2, viewport.Y/2)
    FOVCircle.Visible = Config.Aimbot.Enabled

    if IsAiming and Config.Aimbot.Enabled then
        if Config.Aimbot.LockTarget then
            if LockedTarget then
                if IsTargetValid(LockedTarget) then
                    AimAt(LockedTarget)
                    CurrentTarget = LockedTarget
                else
                    LockedTarget = nil
                    CurrentTarget = nil
                end
            end
        else
            local target = GetClosestTarget()
            if target then AimAt(target)
            else CurrentTarget = nil end
        end
    end

    if TriggerBotCheck() then TriggerBotFire() end

    UpdateStatus()
    UpdateKDAOverlay()
end)

