local function GetClosestTarget()
    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X/2, viewport.Y/2)
    local best, bestScore = nil, -math.huge

    if Config.Aimbot.HoldTarget and CurrentTarget then
        if IsAlive(CurrentTarget) then
            local char = CurrentTarget.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    local sp, on = Camera:WorldToViewportPoint(head.Position)
                    if on then
                        local v = Vector2.new(sp.X, sp.Y)
                        local d = (v - center).Magnitude
                        if d < Config.Aimbot.FOV then
                            return CurrentTarget
                        end
                    end
                end
            end
        end
        CurrentTarget = nil
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not IsAlive(p) then continue end
        if Config.Aimbot.TeamCheck and IsTeam(p) then continue end

        local char = p.Character
        if not char then continue end
        local head = char:FindFirstChild("Head")
        if not head then continue end

        local sp, on = Camera:WorldToViewportPoint(head.Position)
        if not on then continue end

        local v = Vector2.new(sp.X, sp.Y)
        local distToCenter = (v - center).Magnitude

        if distToCenter > Config.Aimbot.FOV then continue end

        local score = -distToCenter

        if Config.Aimbot.Magnetic then
            local magneticBonus = (1 - distToCenter / Config.Aimbot.FOV) * Config.Aimbot.MagneticStrength * 30
            score = score - magneticBonus
        end

        if score > bestScore then
            bestScore = score
            best = p
        end
    end

    if best then CurrentTarget = best
    else CurrentTarget = nil end
    return best
end

local function IsTargetValid(player)
    if not player then return false end
    if not IsAlive(player) then return false end
    if Config.Aimbot.TeamCheck and IsTeam(player) then return false end

    local char = player.Character
    if not char then return false end
    local head = char:FindFirstChild("Head")
    if not head then return false end

    local sp, on = Camera:WorldToViewportPoint(head.Position)
    if not on then return false end

    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X/2, viewport.Y/2)
    local v = Vector2.new(sp.X, sp.Y)
    local distToCenter = (v - center).Magnitude

    return distToCenter <= Config.Aimbot.FOV
end

local function AimAt(player)
    if not player then return end
    local char = player.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end

    local sp = Camera:WorldToViewportPoint(head.Position)
    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X/2, viewport.Y/2)

    local deltaX = sp.X - center.X
    local deltaY = sp.Y - center.Y
    local dist = math.sqrt(deltaX^2 + deltaY^2)

    if dist < 0.5 then return end

    local moveX = deltaX
    local moveY = deltaY

    if Config.Aimbot.Magnetic then
        local speedMult = 1 + (dist / Config.Aimbot.FOV) * 0.3
        moveX = moveX * Config.Aimbot.Smoothness * speedMult
        moveY = moveY * Config.Aimbot.Smoothness * speedMult

        local maxStep = 35
        moveX = math.clamp(moveX, -maxStep, maxStep)
        moveY = math.clamp(moveY, -maxStep, maxStep)
    else
        moveX = math.clamp(deltaX * Config.Aimbot.Smoothness, -20, 20)
        moveY = math.clamp(deltaY * Config.Aimbot.Smoothness, -20, 20)
    end

    mousemoverel(moveX, moveY)
end

