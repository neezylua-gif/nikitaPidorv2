-- VELOCITY SPOOFER
-- =====================================================
local function StartVelocitySpoofer()
    if VelocitySpooferRunning then return end
    VelocitySpooferRunning = true

    VelocitySpooferConnection = RunService.Heartbeat:Connect(function()
        if not Config.VelocitySpoofer.Enabled then
            StopVelocitySpoofer()
            return
        end

        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local origVelocity = hrp.Velocity

        local randX = math.random(Config.VelocitySpoofer.X_Min * 100, Config.VelocitySpoofer.X_Max * 100) / 100
        local randY = math.random(Config.VelocitySpoofer.Y_Min * 100, Config.VelocitySpoofer.Y_Max * 100) / 100
        local randZ = math.random(Config.VelocitySpoofer.Z_Min * 100, Config.VelocitySpoofer.Z_Max * 100) / 100

        hrp.Velocity = Vector3.new(randX, randY, randZ)
        task.wait(Config.VelocitySpoofer.Interval)
        hrp.Velocity = origVelocity
    end)
end

local function StopVelocitySpoofer()
    VelocitySpooferRunning = false
    if VelocitySpooferConnection then
        VelocitySpooferConnection:Disconnect()
        VelocitySpooferConnection = nil
    end
end

