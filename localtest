local function IsOnGround()
    local char = LocalPlayer.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local hum = char:FindFirstChild("Humanoid")
    if hum and hum.FloorMaterial and hum.FloorMaterial ~= Enum.Material.Air then
        return true
    end
    
    local rayOrigin = hrp.Position
    local rayDirection = Vector3.new(0, -Config.BunnyHop.GroundCheckDistance, 0)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local rayResult = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    
    return rayResult ~= nil
end

local function GetVelocity()
    local char = LocalPlayer.Character
    if not char then return Vector3.zero end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return Vector3.zero end
    
    return hrp.Velocity
end

local function SetVelocity(velocity)
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    hrp.Velocity = velocity
end

local function GetHorizontalVelocity()
    local vel = GetVelocity()
    return Vector3.new(vel.X, 0, vel.Z)
end

local function GetHorizontalSpeed()
    return GetHorizontalVelocity().Magnitude
end

local function DoJump()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    hum.Jump = true
    LastJumpTime = tick()
end

local function CalculateStrafeVelocity()
    local char = LocalPlayer.Character
    if not char then return nil end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return nil end
    
    local currentVelocity = hrp.Velocity
    local horizontalVelocity = Vector3.new(currentVelocity.X, 0, currentVelocity.Z)
    local currentSpeed = horizontalVelocity.Magnitude
    
    if currentSpeed < 1 then return nil end
    
    local cameraCFrame = Camera.CFrame
    local moveDirection = Vector3.zero
    
    local keysPressed = {
        W = UserInputService:IsKeyDown(Enum.KeyCode.W),
        A = UserInputService:IsKeyDown(Enum.KeyCode.A),
        S = UserInputService:IsKeyDown(Enum.KeyCode.S),
        D = UserInputService:IsKeyDown(Enum.KeyCode.D)
    }
    
    if keysPressed.W then moveDirection = moveDirection + cameraCFrame.LookVector end
    if keysPressed.S then moveDirection = moveDirection - cameraCFrame.LookVector end
    if keysPressed.A then moveDirection = moveDirection - cameraCFrame.RightVector end
    if keysPressed.D then moveDirection = moveDirection + cameraCFrame.RightVector end
    
    if moveDirection.Magnitude < 0.1 then
        moveDirection = cameraCFrame.LookVector
    end
    
    moveDirection = Vector3.new(moveDirection.X, 0, moveDirection.Z).Unit
    local targetSpeed = Config.BunnyHop.StrafeSpeed * 10
    
    if currentSpeed < targetSpeed then
        local addVelocity = moveDirection * (targetSpeed - currentSpeed) * Config.BunnyHop.StrafeSmoothness
        return horizontalVelocity + addVelocity
    elseif currentSpeed > targetSpeed then
        local normalizedVelocity = horizontalVelocity.Unit
        local dotProduct = normalizedVelocity:Dot(moveDirection)
        
        if dotProduct > 0.7 then
            local speedToAdd = targetSpeed * 0.3
            local addVelocity = moveDirection * speedToAdd * Config.BunnyHop.StrafeSmoothness
            return horizontalVelocity + addVelocity
        else
            local newDirection = (normalizedVelocity + moveDirection * Config.BunnyHop.StrafeSmoothness).Unit
            return newDirection * targetSpeed
        end
    end
    
    return nil
end

local function BunnyHopLogic()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    if hum.Health <= 0 then return end
    
    local onGround = IsOnGround()
    
    if onGround and not WasOnGround then
        DoJump()
        
        if Config.BunnyHop.AutoStrafe and Config.BunnyHop.UseVelocity then
            local newVel = CalculateStrafeVelocity()
            if newVel then
                local currentY = GetVelocity().Y
                SetVelocity(Vector3.new(newVel.X, currentY, newVel.Z))
            end
        end
    end
    
    if not onGround and Config.BunnyHop.AutoStrafe and Config.BunnyHop.UseVelocity then
        local newVel = CalculateStrafeVelocity()
        if newVel then
            local currentY = GetVelocity().Y
            SetVelocity(Vector3.new(newVel.X, currentY, newVel.Z))
        end
        
        local horizontalSpeed = GetHorizontalSpeed()
        if horizontalSpeed < Config.BunnyHop.StrafeSpeed * 8 then
            local moveDir = Camera.CFrame.LookVector
            moveDir = Vector3.new(moveDir.X, 0, moveDir.Z).Unit
            local boostVelocity = moveDir * Config.BunnyHop.StrafeSpeed * 2
            local currentVel = GetVelocity()
            SetVelocity(Vector3.new(
                currentVel.X + boostVelocity.X * 0.1,
                currentVel.Y,
                currentVel.Z + boostVelocity.Z * 0.1
            ))
        end
    end
    
    WasOnGround = onGround
end

local function StartBunnyHop()
    if BunnyHopRunning then return end
    BunnyHopRunning = true
    
    BunnyHopConnection = RunService.RenderStepped:Connect(function()
        if not Config.BunnyHop.Enabled then
            StopBunnyHop()
            return
        end
        
        if Config.BunnyHop.HoldSpaceOnly and not IsSpaceHeld then
            return
        end
        
        BunnyHopLogic()
    end)
end

local function StopBunnyHop()
    BunnyHopRunning = false
    if BunnyHopConnection then
        BunnyHopConnection:Disconnect()
        BunnyHopConnection = nil
    end
end

